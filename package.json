{
  "name": "@musekit/email",
  "version": "0.1.0",
  "description": "Email system for MuseKit SaaS platform using Resend",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    }
  },
  "files": [
    "dist/lib"
  ],
  "scripts": {
    "dev": "vite",
    "build:lib": "tsc -p tsconfig.lib.json",
    "build": "npm run build:lib && vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "musekit",
    "email",
    "resend"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "@react-email/components": "^1.0.8",
    "@supabase/supabase-js": "^2.98.0",
    "resend": "^6.9.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "lucide-react": "^0.577.0",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
